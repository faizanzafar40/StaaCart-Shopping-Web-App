# Copy these into your web server's environment (e.g. Apache SetEnv, a .env
# loader, or your shell) to point StaaCart at your own MySQL database.
# If they are not set, dbconnect.php falls back to a local XAMPP-style setup
# (localhost / root / no password / webstaacart1).

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=webstaacart1
